# --------------------------------------------------
# APP
# --------------------------------------------------
APP_NAME=AI Legal Assistant
APP_ENV=development
DEBUG=True
API_V1_PREFIX=/api/v1

# --------------------------------------------------
# JWT
# --------------------------------------------------
JWT_SECRET_KEY=change-this-super-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --------------------------------------------------
# GOOGLE OAUTH
# --------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# --------------------------------------------------
# FIREBASE
# --------------------------------------------------
# Path to firebase service account JSON key file (local)
FIREBASE_CREDENTIALS_PATH=app/config/firebase-service-account.json
# Base64-encoded service account JSON (for Railway/Vercel deploy — overrides file path)
FIREBASE_SERVICE_ACCOUNT_B64=
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com

# --------------------------------------------------
# SUPABASE
# --------------------------------------------------
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# --------------------------------------------------
# LLM / LANGCHAIN
# --------------------------------------------------
OPENAI_API_KEY=your-openai-api-key
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
LLM_PROVIDER=gemini
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
FAISS_INDEX_DIR=app/database/faiss_indexes

# --------------------------------------------------
# WHISPER
# --------------------------------------------------
WHISPER_MODEL_SIZE=base

# --------------------------------------------------
# RATE LIMITING
# --------------------------------------------------
RATE_LIMIT_PER_MINUTE=30

# --------------------------------------------------
# FILE UPLOAD
# --------------------------------------------------
MAX_UPLOAD_SIZE_MB=15
UPLOAD_DIR=app/uploads

# --------------------------------------------------
# CORS
# --------------------------------------------------
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-vercel-app.vercel.app

# --------------------------------------------------
# LOGGING
# --------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=logs
